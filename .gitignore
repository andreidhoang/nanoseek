# ==============================================================================
# NanoSeek .gitignore - Open Source Release
# ==============================================================================

# ==============================================================================
# Python
# ==============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ==============================================================================
# Virtual Environments
# ==============================================================================
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
.python-version

# ==============================================================================
# Model Checkpoints & Weights (large files)
# ==============================================================================
checkpoints/
*.pt
*.pth
*.bin
*.safetensors
*.ckpt
*.onnx

# ==============================================================================
# Data (large files - users download separately)
# ==============================================================================
data/
*.arrow
*.parquet
*.jsonl.gz

# ==============================================================================
# Logs & Outputs
# ==============================================================================
logs/
*.log
wandb/
runs/
outputs/
results/

# ==============================================================================
# Jupyter Notebook Checkpoints
# ==============================================================================
.ipynb_checkpoints/

# ==============================================================================
# IDE & Editors
# ==============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace

# ==============================================================================
# macOS
# ==============================================================================
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ==============================================================================
# Testing & Coverage
# ==============================================================================
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.hypothesis/
nosetests.xml
coverage.xml
*.cover
.cache

# ==============================================================================
# Build & Distribution
# ==============================================================================
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt

# ==============================================================================
# Misc
# ==============================================================================
*.bak
*.tmp
*.temp
.benchmarks/
profile_results/
*.prof

# ==============================================================================
# Private/Local Files (not for open source)
# ==============================================================================
.claude/
tasks/
kernels/
tutorials/
nanochat/
notebooks/
CLAUDE.md
*.local.py
*.local.yaml
secrets/
credentials/
